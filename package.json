{
  "name": "pi-model-staging",
  "version": "0.1.0",
  "description": "A pi extension that adds plan-then-execute mode with a per-run and per-turn model ladder for staged thinking-level / model stepping.",
  "private": false,
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "plan-mode",
    "model-staging",
    "model-ladder"
  ],
  "pi": {
    "extensions": [
      "./.pi/extensions/plan-stepdown"
    ]
  },
  "scripts": {
    "test": "node --test --experimental-strip-types --no-warnings .pi/extensions/plan-stepdown/rewrite.test.ts"
  },
  "engines": {
    "node": ">=22"
  }
}
